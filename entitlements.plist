<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for code-signing the (PyInstaller) WannaTapThat bundle with a
  Developer ID + hardened runtime so it can be notarized. A bundled Python
  interpreter loads unsigned .so/.dylib files and uses executable memory, so
  notarization under the hardened runtime requires these exceptions.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
